# OBLIGATORIO — Agente real con Google Gemini (sin esto la búsqueda no funciona)
# Obtener gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Secreto para sesiones de login (mínimo 16 caracteres)
AUTH_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# Correos con Resend — https://resend.com (100 emails/día gratis)
# API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx
# Remitente (sin dominio verificado usar: NexSync <onboarding@resend.dev>)
RESEND_FROM=NexSync <onboarding@resend.dev>
# Copia interna de cada contrato para la plataforma
PLATFORM_EMAIL=tu_correo@gmail.com
